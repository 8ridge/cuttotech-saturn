# ─── Database ───────────────────────────────
# On Saturn/Railway: provided automatically when you attach a PostgreSQL service.
# Locally: set up Postgres on localhost:5432
DATABASE_URL=postgresql://user:password@localhost:5432/cuttotech

# ─── Server ───────────────────────────────
# On Saturn/Railway: PORT is provided by the platform — your server binds to process.env.PORT
PORT=3000
NODE_ENV=production

# Public URL of your deployed app (used for short links, OAuth callbacks, emails).
# On Saturn: e.g. https://cuttotech.saturn.ac
# On Railway: e.g. https://cuttotech-production.up.railway.app
BASE_URL=https://your-app.saturn.ac
FRONTEND_URL=https://your-app.saturn.ac

# ─── JWT ───────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d

# ─── Google OAuth (optional) ───────────────────────────────
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must match: ${BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.saturn.ac/auth/google/callback

# ─── Email (Resend) — optional ───────────────────────────────
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=CutToTech <noreply@cutto.tech>
